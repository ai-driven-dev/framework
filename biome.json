{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "es5"
    }
  },
  "files": {
    "includes": [
      "**",
      "!**/dist",
      "!**/node_modules",
      "!**/example",
      "!**/temp",
      "!**/coverage",
      "!demo",
      "!.aidd",
      "!.claude",
      "!.cursor",
      "!.opencode",
      "!.specstory",
      "!.vscode",
      "!setup-test",
      "!tmp-test",
      "!tmp",
      "!.stryker-tmp",
      "!reports",
      "!**/fixtures/**/*.json"
    ]
  },
  "overrides": [
    {
      "includes": ["**/package.json"],
      "formatter": { "enabled": false }
    }
  ]
}
