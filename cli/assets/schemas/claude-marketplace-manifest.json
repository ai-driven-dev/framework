{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "Hand-crafted Claude marketplace manifest schema. Mirrors https://json.schemastore.org/claude-code-marketplace.json shape. Validated against tests/fixtures/framework-real/.claude-plugin/marketplace.json on 2026-05-26. Used by the codex build target to validate emitted .claude-plugin/marketplace.json output.",
  "type": "object",
  "required": ["name", "plugins"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the marketplace collection."
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "owner": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "$schema": {
      "type": "string"
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "source", "description", "version"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string"
          },
          "source": {
            "type": "string",
            "description": "Relative path from the marketplace file to the plugin directory (e.g. './plugins/aidd-dev')."
          },
          "description": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "strict": {
            "type": "boolean"
          },
          "recommended": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
