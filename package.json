{
  "name": "@ai-driven-dev/cli",
  "version": "4.1.0-beta.5",
  "description": "AI-Driven Development CLI — install AI tool configs and plugins from the AIDD marketplace",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "aidd": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "pnpm build && vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:e2e": "pnpm build && vitest run --project=e2e",
    "test:watch": "vitest",
    "smoke": "bash scripts/smoke-all.sh",
    "smoke:marketplace": "pnpm build && bash scripts/smoke-marketplace.sh",
    "smoke:regression": "pnpm build && bash scripts/smoke-regression.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip:production": "knip --production --exclude exports,types",
    "jscpd": "jscpd src/",
    "pack:local": "pnpm build && pnpm pack --pack-destination ./dist",
    "install:local": "pnpm run pack:local && npm install -g ./dist/ai-driven-dev-cli-$(node -p \"require('./package.json').version\").tgz --force",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0",
    "simple-git": "^3.36.0",
    "smol-toml": "^1.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jscpd": "^4.0.0",
    "knip": "^5.0.0",
    "lefthook": "^1.13.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
