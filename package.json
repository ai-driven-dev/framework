{
  "name": "@ai-driven-dev/cli",
  "version": "2.1.0",
  "description": "AI-Driven Development CLI — distribute the AIDD framework across AI coding assistants",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "aidd": "dist/cli.js"
  },
  "files": ["dist", "README.md"],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip:production": "knip --production",
    "jscpd": "jscpd src/",
    "pack:local": "pnpm build && pnpm pack --pack-destination ./dist",
    "install:local": "pnpm run pack:local && npm install -g ./dist/ai-driven-dev-cli-$(node -p \"require('./package.json').version\").tgz --force",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@types/node": "^24.0.0",
    "jscpd": "^4.0.0",
    "knip": "^5.0.0",
    "lefthook": "^1.13.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
