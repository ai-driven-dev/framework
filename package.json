{
  "name": "@ai-driven-dev/aidd-cli",
  "version": "3.0.0",
  "description": "AI-Driven Development CLI — distribute the AIDD framework across AI coding assistants",
  "type": "module",
  "bin": {
    "aidd": "dist/cli.js"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "knip:production": "knip --production",
    "jscpd": "jscpd src/",
    "pack:local": "pnpm build && pnpm pack --pack-destination ./dist",
    "install:local": "pnpm run pack:local && npm install -g ./dist/ai-driven-dev-aidd-cli-$(node -p \"require('./package.json').version\").tgz --force"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^24.0.0",
    "jscpd": "^4.0.0",
    "knip": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
