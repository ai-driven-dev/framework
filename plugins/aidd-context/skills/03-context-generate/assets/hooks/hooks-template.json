{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "{{event_name}}": [
      {
        "matcher": "{{matcher}}",
        "hooks": [
          {
            "type": "{{handler_type}}",
            "command": "{{command}}",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
